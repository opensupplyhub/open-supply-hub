#!/bin/bash
set -e

if [[ -n "${OAR_DEBUG}" ]]; then
    set -x
fi

function usage() {
    echo -n \
"Usage: $(basename "$0") COMMAND OPTION[S]
Execute Terraform subcommands with remote state management.
"
}

CONTRIBOT_LAMBDAS=(
    contribot_fetch_lists
    contribot_process_list
    contribot_notify
)

function upload_contribot_lambda_zips() {
    local lambda
    echo "Uploading ContriBot Lambda archives to s3://${SETTINGS_BUCKET}/terraform/lambda/"
    for lambda in "${CONTRIBOT_LAMBDAS[@]}"; do
        aws s3 cp \
            "lambda-functions/${lambda}/${lambda}.zip" \
            "s3://${SETTINGS_BUCKET}/terraform/lambda/${lambda}.zip"
    done
}

function download_contribot_lambda_zips() {
    local lambda
    echo "Downloading ContriBot Lambda archives from s3://${SETTINGS_BUCKET}/terraform/lambda/"
    for lambda in "${CONTRIBOT_LAMBDAS[@]}"; do
        aws s3 cp \
            "s3://${SETTINGS_BUCKET}/terraform/lambda/${lambda}.zip" \
            "lambda-functions/${lambda}/${lambda}.zip"
    done
}

function delete_contribot_lambda_zips() {
    local lambda
    echo "Deleting ContriBot Lambda archives from s3://${SETTINGS_BUCKET}/terraform/lambda/"
    for lambda in "${CONTRIBOT_LAMBDAS[@]}"; do
        aws s3 rm "s3://${SETTINGS_BUCKET}/terraform/lambda/${lambda}.zip" || true
    done
}

# # Temporary solution
# GIT_COMMIT="latest"

if [[ -n "${GIT_COMMIT}" ]]; then
    GIT_COMMIT="${GIT_COMMIT:0:7}"
else
    SHORT_SHA="$(git rev-parse --short HEAD)"
    GIT_COMMIT="${SHORT_SHA:0:7}"

fi

if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    if [ "${1:-}" = "--help" ]; then
        usage
    else
        TERRAFORM_DIR="$(dirname "$0")/../deployment/terraform"
        echo
        echo "Attempting to deploy application version [${GIT_COMMIT}]..."
        echo "-----------------------------------------------------"
        echo
    fi

    if [[ -n "${SETTINGS_BUCKET}" ]]; then
        pushd "${TERRAFORM_DIR}"
        git config --global --add safe.directory /usr/local/src

        case "${1}" in
            plan)
                # DEFAULT_BATCH_CE_DESIRED_CPU=$(aws batch describe-compute-environments --output text --compute-environments "batch${OAR_DEPLOYMENT_ENVIRONMENT^}DefaultComputeEnvironment" --query "computeEnvironments[].computeResources.desiredvCpus")

                # Build Lambda function archives
                make -sC lambda-functions/alert_batch_failures
                make -sC lambda-functions/alert_sfn_failures
                make -sC lambda-functions/contribot_fetch_lists
                make -sC lambda-functions/contribot_process_list
                make -sC lambda-functions/contribot_notify

                # Clear stale modules & remote state, then re-initialize
                echo "Terraform init"
                rm -rf .terraform terraform.tfstate*
                terraform init \
                  -backend-config="bucket=${SETTINGS_BUCKET}" \
                  -backend-config="key=terraform/state"
                echo "Terraform plan"
                terraform plan \
                          -no-color \
                          -var="image_tag=${GIT_COMMIT}" \
                          -var="batch_default_ce_desired_vcpus=${DEFAULT_BATCH_CE_DESIRED_CPU:-0}" \
                          -var-file="${SETTINGS_BUCKET}.tfvars" \
                          -out="${SETTINGS_BUCKET}.tfplan" \
                          > "${SETTINGS_BUCKET}.tfplan.log.txt" 2>&1

                # Pass gitignored ContriBot zips to the apply job (same bytes as plan)
                upload_contribot_lambda_zips
                ;;
            apply)
                # Use the exact archives hashed during plan
                download_contribot_lambda_zips

                echo "Terraform init"
                rm -rf .terraform terraform.tfstate*
                terraform init \
                  -backend-config="bucket=${SETTINGS_BUCKET}" \
                  -backend-config="key=terraform/state"
                echo "Terraform apply"
                ls -la
                terraform apply "${SETTINGS_BUCKET}.tfplan"
                delete_contribot_lambda_zips
                ;;
            destroy)
                terraform init \
                  -backend-config="bucket=${SETTINGS_BUCKET}" \
                  -backend-config="key=terraform/state"
                terraform destroy \
                          -var="image_tag=${GIT_COMMIT}" \
                          -var="batch_default_ce_desired_vcpus=${DEFAULT_BATCH_CE_DESIRED_CPU:-0}" \
                          -var-file="${SETTINGS_BUCKET}.tfvars" \
                          --auto-approve \
                          -input=false
                ;;
            *)
                echo "ERROR: I don't have support for that Terraform subcommand!"
                exit 1
                ;;
        esac

        popd
    else
        echo "ERROR: No OAR_SETTINGS_BUCKET variable defined."
        exit 1
    fi
fi
