# Central usage-sink config for the skill/command/sub-agent logger.
#
# Copy this file to ".claude/usage-sink.local" (which is gitignored) and fill in
# the values shared with you out-of-band. Once present, log_usage.py will POST
# usage rows to the Google Sheet. Without it, logging stays local-only — nothing
# breaks, you just don't contribute to the central aggregate.
#
#   cp .claude/usage-sink.local.example .claude/usage-sink.local
#   # then edit .claude/usage-sink.local with the real values
#
# Environment variables of the same name take precedence over this file.

# Google Apps Script web-app URL that appends to the usage Sheet (kept secret —
# never commit the real value; this repo is public).
OSHUB_USAGE_LOG_URL=

# OPTIONAL. A default salt is built in, so you can leave this blank. Only set it
# if the team agreed on a custom shared salt for stronger anonymity — and then
# everyone must use the SAME value, or distinct-user counts break.
OSHUB_USAGE_LOG_SALT=
